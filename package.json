{
  "name": "epr-re-ex-admin-frontend-tests",
  "version": "0.0.0",
  "type": "module",
  "description": "",
  "engines": {
    "node": "^24.18.0"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "aliases": {
    "~": ".",
    "page-objects": "test/page-objects",
    "components": "test/components"
  },
  "scripts": {
    "clean": "rm -rf allure-results && rm -rf allure-report",
    "format:check": "prettier --check 'test/**/*.js' '**/*.{js,md,json,config.js}'",
    "format": "prettier --write 'test/**/*.js' '**/*.{js,md,json,config.js}'",
    "lint:fix": "eslint . --fix",
    "lint:types": "tsc -p jsconfig.typecheck.json",
    "lint": "eslint .",
    "postinstall": "npm run setup:husky",
    "report:publish": "npm run report; ./bin/publish-tests.sh",
    "report": "allure generate allure-results --single-file --clean",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "test:browserstack": "npm run clean && wdio run wdio.browserstack.conf.js",
    "test:github:browserstack": "npm run clean && wdio run wdio.github.browserstack.conf.js",
    "test:github": "npm run clean && GREP='@smoketest' GREP_INVERT=true wdio run wdio.github.conf.js",
    "test:local:debug": "npm run clean && GREP='@smoketest' GREP_INVERT=true DEBUG=true wdio run wdio.local.conf.js",
    "test:local:grep": "npm run clean && wdio run wdio.local.conf.js",
    "test:local": "npm run clean && GREP='@smoketest' GREP_INVERT=true wdio run wdio.local.conf.js",
    "test": "npm run clean && GREP='@smoketest' wdio run wdio.conf.js"
  },
  "dependencies": {
    "@axe-core/webdriverio": "4.12.1",
    "@faker-js/faker": "10.5.0",
    "@wdio/allure-reporter": "9.29.0",
    "@wdio/browserstack-service": "9.29.0",
    "@wdio/cli": "9.29.0",
    "@wdio/globals": "9.29.0",
    "@wdio/junit-reporter": "9.29.0",
    "@wdio/local-runner": "9.29.0",
    "@wdio/mocha-framework": "9.29.0",
    "@wdio/spec-reporter": "9.29.0",
    "allure-commandline": "2.43.0",
    "esm-module-alias": "2.2.1",
    "exceljs": "4.4.0",
    "global-agent": "4.1.3",
    "undici": "8.5.0"
  },
  "overrides": {
    "eslint": "$eslint",
    "form-data": "4.0.6",
    "@grpc/grpc-js": "1.13.5",
    "serialize-javascript": "7.0.5",
    "undici": "$undici",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-wdio": "9.29.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "neostandard": "0.13.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3"
  }
}
